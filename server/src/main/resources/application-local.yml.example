# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to application-local.yml (gitignored) for local overrides.
# application-local.yml is loaded on top of application.yml.
#
# DB is OFF by default. To turn it on, activate the "db" Spring profile:
#
#   cd server && SPRING_PROFILES_ACTIVE=local,db ./gradlew bootRun
#
# See CONVENTIONS.md § 8 for the full story.
# ──────────────────────────────────────────────────────────────────────────────

# Local DB credential overrides (only needed when running with the "db" profile)
# Defaults in application.yml already point to localhost:5432/halo / halo / halo_secret
# so this file can stay empty unless you need different values.
#
# spring:
#   datasource:
#     url: jdbc:postgresql://localhost:5432/halo
#     username: halo
#     password: halo_secret
#   jpa:
#     show-sql: true
#     properties:
#       hibernate:
#         format_sql: true
